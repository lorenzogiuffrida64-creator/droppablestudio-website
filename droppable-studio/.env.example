# ── Inquiry form notifications (Resend) ───────────────────────────────────────
# Copy this file to .env.local for local dev, and add the same vars in Vercel
# (Project → Settings → Environment Variables) for production.

# 1) Create a free account at https://resend.com and make an API key.
RESEND_API_KEY=re_your_resend_api_key_here

# 2) Who receives the inquiry email — comma-separated, as many as you want.
INQUIRY_TO=you@droppablestudio.com,partner@droppablestudio.com

# 3) The "from" address. For real sending you must verify your domain in Resend
#    (Resend → Domains) and use an address at that domain, e.g.:
#      INQUIRY_FROM=Droppable Studio <inquiries@droppablestudio.com>
#    Until your domain is verified you can test with Resend's shared sender:
INQUIRY_FROM=Droppable Studio <onboarding@resend.dev>

# ── Skool pre-order checkout (Stripe) ─────────────────────────────────────────
# 1) Stripe secret key — use a test key (sk_test_…) while building, the live key
#    (sk_live_…) at launch. Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# 2) Webhook signing secret. Local dev: run
#      stripe listen --forward-to localhost:3000/api/stripe/webhook
#    and copy the whsec_… it prints. Production: Stripe Dashboard → Developers →
#    Webhooks → add endpoint https://yourdomain.com/api/stripe/webhook
#    (event: checkout.session.completed) → copy its signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# 3) Who gets the "new pre-order" notification (comma-separated). Falls back to
#    INQUIRY_TO if unset. Buyer confirmation + sending reuse RESEND_API_KEY /
#    INQUIRY_FROM above.
PREORDER_TO=you@droppablestudio.com

# 4) Optional: absolute site URL used to build Stripe success/cancel links.
#    If unset, the request origin is used (fine for local + most deploys).
# NEXT_PUBLIC_SITE_URL=https://droppablestudio.com
